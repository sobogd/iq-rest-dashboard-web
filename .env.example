# Optional. Leave empty to use Vite proxy (relative /api).
# Set explicit URL when frontend and API are on different origins.
# VITE_API_URL=https://api.example.com/api

# Origin of the dashboard SPA. Falls back to window.location.origin.
VITE_APP_URL=https://your-dashboard-domain.com

# Public QR menu site origin (separate Next.js app at iq-rest.com).
# QR codes, share links, and menu previews point here.
VITE_PUBLIC_MENU_URL=https://iq-rest.com

# Admin email domain for admin panel access.
VITE_ADMIN_EMAIL_DOMAIN=iq-rest.com

# Google Maps API key (location picker in contacts settings).
VITE_GOOGLE_MAPS_API_KEY=
